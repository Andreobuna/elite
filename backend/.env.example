# ==========================================
# Elite X Shop - Backend Environment Variables
# Copy this file to .env and fill in real values.
# ==========================================

# --- Server ---
APP_PORT=4000
NODE_ENV=development
# Comma-separated CORS allowlist. Keep localhost here for local dev.
CORS_ORIGINS=CORS_ORIGINS=https://www.elitexshop.com
CLIENT_URL=http://www.elitexshop.com

# --- Database (PostgreSQL) ---
DATABASE_URL="postgresql://neondb_owner:npg_Ugf8OZbL5iJl@ep-weathered-firefly-awk64bw6-pooler.c-12.us-east-1.aws.neon.tech/neondb?sslmode=require&channel_binding=require"
DIRECT_URL="postgresql://neondb_owner:npg_Ugf8OZbL5iJl@ep-weathered-firefly-awk64bw6.c-12.us-east-1.aws.neon.tech/neondb?sslmode=require&channel_binding=require"
DATABASE_URL_POOLER="postgresql://neondb_owner:npg_Ugf8OZbL5iJl@ep-weathered-firefly-awk64bw6-pooler.c-12.us-east-1.aws.neon.tech/neondb?sslmode=require&channel_binding=require"

# --- JWT ---
JWT_ACCESS_SECRET=replace_with_a_long_random_string
JWT_REFRESH_SECRET=replace_with_a_different_long_random_string
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=30d

# --- CJ Dropshipping API ---
CJ_API_KEY=replace-with-your-cj-api-key
CJ_API_SECRET=replace-with-your-cj-api-secret
CJ_ACCESS_TOKEN=
CJ_REFRESH_TOKEN=
CJ_API_BASE_URL=https://developers.cjdropshipping.com/api2.0/v1
CJ_COUNTRY=US
CJ_LANGUAGE=en

# Legacy CJ env names are still accepted by the backend as fallbacks.
CJ_API_KEY=CJ5616928@api@84d04cf2746c4da094339d240645b48a
CJ_API_SECRET=
CJ_SESSION=
CJ_API_BASE_URL=https://developers.cjdropshipping.com/api2.0/v1

# --- Default markup applied to imported products (percent) ---
DEFAULT_MARKUP_PERCENT=10

# --- Cloudinary ---
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# --- Stripe ---
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# --- PayPal ---
PAYPAL_CLIENT_ID=
PAYPAL_CLIENT_SECRET=
PAYPAL_MODE=sandbox

# --- Paystack ---
PAYSTACK_SECRET_KEY=

# --- Flutterwave ---
FLUTTERWAVE_SECRET_KEY=

# --- Email (SMTP via Nodemailer) ---
SMTP_HOST=smtp.mailtrap.io
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
EMAIL_FROM="Elite X Shop <no-reply@elitexshop.com>"

# --- Rate limiting ---
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=200