# Production backend env
APP_PORT=10000
NODE_ENV=production
# Comma-separated CORS allowlist for production and legacy deployments.
CORS_ORIGINS=https://www.elitexshop.com,https://elitexshop.com
CLIENT_URL=https://www.elitexshop.com
DATABASE_URL=postgresql://...
DIRECT_URL=postgresql://...
DATABASE_URL_POOLER=postgresql://...
JWT_ACCESS_SECRET=replace_with_a_long_random_string
JWT_REFRESH_SECRET=replace_with_a_different_long_random_string
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=30d
CJ_API_KEY=
CJ_API_SECRET=
CJ_ACCESS_TOKEN=
CJ_REFRESH_TOKEN=
CJ_API_BASE_URL=https://developers.cjdropshipping.com/api2.0/v1
CJ_COUNTRY=US
CJ_LANGUAGE=en
DEFAULT_MARKUP_PERCENT=10
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=200